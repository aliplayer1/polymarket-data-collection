[Unit]
Description=Polymarket Historical Data Sync + Hugging Face Upload (one-shot)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=no
User=polymarket
Group=polymarket
WorkingDirectory=/opt/polymarket

EnvironmentFile=/opt/polymarket/.env

# Incremental scan (checkpoint-based; typically 1-2 pages after the first run)
# then uploads all Parquet data to Hugging Face Hub.
ExecStart=/opt/polymarket/.venv/bin/python -m polymarket_pipeline \
    --historical-only \
    --upload

# Allow up to 2 h for an unusually large backfill run
TimeoutStartSec=7200
