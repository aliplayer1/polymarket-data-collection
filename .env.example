# ── On-chain tick data ────────────────────────────────────────────────────────
# Historical OrderFilled fills come from Polymarket's orderbook subgraph
# (Goldsky primary, optional Graph-Network fallback when SUBGRAPH_API_KEY is
# set).  No Polygon RPC or Polygonscan credential is required.
#
# Optional: set to The Graph Studio API key to enable the fallback endpoint
# when Goldsky is unreachable.  Get one at https://thegraph.com/studio/.
SUBGRAPH_API_KEY=

# Optional: set to "1" to disable on-chain tick backfill entirely (e.g. for
# ad-hoc runs that only need price history).  Leave unset for normal operation.
PM_DISABLE_TICK_BACKFILL=

# ── Hugging Face Hub upload (--upload flag) ───────────────────────────────────
# Write token from https://huggingface.co/settings/tokens
HF_TOKEN=

# Dataset repo to upload to (default used when --hf-repo is not specified).
# The repo is created automatically if it does not exist.
HF_REPO_ID=polymarket-crypto-updown

# ── Storage paths (optional overrides) ───────────────────────────────────────
# Root directory for Parquet output (markets.parquet, prices/, ticks/).
# Defaults to data/ relative to the working directory.
# Set to an absolute path when running on a cloud instance with a dedicated
# block volume, e.g.:  /mnt/data/polymarket
POLYMARKET_DATA_DIR=

# Append log output to this file in addition to stdout.
# Parent directories are created automatically.
# e.g.:  /var/log/polymarket/pipeline.log
POLYMARKET_LOG_FILE=

# ── DuckDB consolidation tuning (optional) ────────────────────────────────────
# Used by --upload / --upload-only when shard files are consolidated before the
# Hugging Face upload. Leave unset to auto-size from the effective system/cgroup
# memory limit and use a single DuckDB thread.
#
# Examples:
#   PM_DUCKDB_MEMORY_LIMIT=3GB
#   PM_DUCKDB_THREADS=1
PM_DUCKDB_MEMORY_LIMIT=
PM_DUCKDB_THREADS=

# Parent directory for DuckDB consolidation spill files.
#
# Default resolution order:
#   1. PM_DUCKDB_TEMP_DIR (this var)
#   2. /var/tmp           — persistent disk on every Linux distro per FHS;
#                           inherits the root filesystem's free space, NOT
#                           tmpfs.  This is the default to avoid the failure
#                           mode where /tmp tmpfs (capped at ~50% of RAM)
#                           runs out of space mid-consolidation on hot
#                           partitions.
#   3. tempfile.mkdtemp() — final fallback ($TMPDIR / /tmp; may be tmpfs).
#
# Set explicitly to point spill at a dedicated mount (e.g. a separate
# block volume with plenty of free space).  A unique subdirectory is
# created per consolidation pass and removed afterwards, so leftover
# state from interrupted runs self-clears.
#   PM_DUCKDB_TEMP_DIR=/mnt/scratch/duckdb
PM_DUCKDB_TEMP_DIR=

# Maximum number of tick shard files processed in a single DuckDB COPY
# pass during consolidate_ticks.  Default 250 is conservative for the
# CAX21 (DuckDB capped at ~2 GB by the systemd cgroup); raise on hosts
# with more headroom for fewer passes (faster), or lower if individual
# passes still spill too much.
#   PM_TICK_CONSOLIDATION_BATCH_SIZE=250
PM_TICK_CONSOLIDATION_BATCH_SIZE=
