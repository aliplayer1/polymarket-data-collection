# for validation (not part of the repo).
runtime_test/
runtime_test_hist/

# -- Logs ----------------------------------------------------------------------
*.log
*.log.*
# Log dir created by configure_logging() when --log-file is unset
logs/

# -- Misc formats produced during analysis -------------------------------------
*.csv
*.xlsx
*.parquet

