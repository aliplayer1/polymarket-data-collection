# -- Python --------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/

# -- Secrets — never commit credentials ----------------------------------------
.env
.env.*
!.env.example

# -- Collected data — can be very large ----------------------------------------
data/
data-culture/
test_output/
test_output_parquet/
test_data_15m/
